<!--
  Wazuh Docker Final Lab Rules
  Aman untuk PoC defensif:
  - DDoS sintetis berbasis JSON dari 3 agent.
  - Web DDoS lokal berbasis Nginx access.log dari web-target.
  - Malware validation aman berbasis EICAR + YARA.
-->
<group name="wazuh_lab,ddos,web_ddos,malware,yara,">

  <!-- JSON telemetry DDoS dari simulate-ddos.sh -->
  <rule id="100100" level="4">
    <decoded_as>wazuh-lab-json</decoded_as>
    <field name="lab_type">ddos</field>
    <description>Wazuh Lab: DDoS telemetry event received from agent</description>
    <group>ddos,traffic_anomaly,wazuh_lab,</group>
  </rule>

  <rule id="100101" level="10" frequency="60" timeframe="30">
    <if_matched_sid>100100</if_matched_sid>
    <same_field>srcip</same_field>
    <description>Wazuh Lab: High request burst from same source IP - possible HTTP flood</description>
    <group>ddos,traffic_anomaly,wazuh_lab,</group>
  </rule>

  <rule id="100102" level="12" frequency="180" timeframe="30">
    <if_matched_sid>100100</if_matched_sid>
    <description>Wazuh Lab: Distributed high-volume traffic pattern detected across agents</description>
    <group>ddos,distributed_attack,critical,wazuh_lab,</group>
  </rule>

  <rule id="100103" level="7">
    <decoded_as>wazuh-lab-json</decoded_as>
    <field name="lab_type">density</field>
    <description>Wazuh Lab: High logging density or uneven distribution report received</description>
    <group>log_density,distribution,wazuh_lab,</group>
  </rule>

  <!-- Nginx web-target access log. Cocok dengan baris: "GET / HTTP/1.1" -->
  <rule id="100301" level="5">
    <match>GET / HTTP</match>
    <description>Wazuh Lab: Web target HTTP request detected from Nginx access log</description>
    <group>web_ddos,nginx,wazuh_lab,</group>
  </rule>

  <rule id="100302" level="12" frequency="40" timeframe="10">
    <if_matched_sid>100301</if_matched_sid>
    <description>CRITICAL Wazuh Lab: High HTTP request burst detected against local web target</description>
    <group>web_ddos,nginx,ddos,critical,wazuh_lab,</group>
  </rule>

  <!-- Malware validation aman: EICAR + YARA -->
  <rule id="100200" level="12">
    <decoded_as>wazuh-lab-json</decoded_as>
    <field name="lab_type">malware</field>
    <field name="scanner">yara</field>
    <field name="signature">EICAR</field>
    <description>Wazuh Lab: YARA detected EICAR test malware signature</description>
    <group>malware,yara,eicar,critical,wazuh_lab,</group>
  </rule>

  <rule id="100201" level="8">
    <decoded_as>wazuh-lab-json</decoded_as>
    <field name="lab_type">malware_artifact</field>
    <description>Wazuh Lab: Malware test artifact created for operational validation</description>
    <group>malware,fim_validation,wazuh_lab,</group>
  </rule>

</group>
